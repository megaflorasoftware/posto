{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Posto",
  "version": "0.8.6",
  "identifier": "com.henryfellerhoff.posto",
  "build": {
    "beforeDevCommand": "pnpm --filter desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter desktop build",
    "frontendDist": "../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Posto",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        },
        "width": 2400,
        "height": 1350
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5Nzc2Qzk5RkJGNEIwNDcKUldSSHNQVDdtV3gzNlJwci9wVDRuUUJJTFB2cGltWWpSRVowUnZwbjFJc0h1bUFKUThtMytHeUwK",
      "endpoints": [
        "https://github.com/megaflorasoftware/posto/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
