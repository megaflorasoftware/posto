{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Desktop capability for the main window",
  "windows": ["main"],
  "platforms": ["macOS", "linux", "windows"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "updater:default",
    "process:default"
  ]
}
